# QuantumLedger server configuration (copy to .env for docker-compose / local).
QL_DEPLOYMENT=selfhost
# hosted store; use sqlite:///./quantumledger.db for a tiny single-node deploy
QL_DATABASE_URL=postgresql+psycopg://quantumledger:quantumledger@postgres:5432/quantumledger
QL_BASE_URL=http://localhost:8000
QL_SECRET_KEY=change-me-in-production
QL_ATTESTATION_KEY_PATH=/data/attestation_ed25519.key
QL_ADMIN_EMAIL=admin@quantumledger.local
# set false for VPC / air-gapped: public Result Cards & badges resolve only internally
QL_PUBLIC_CARDS=true

# DOI minting. "local" (default) mints a stable offline PID — no network,
# works self-hosted/air-gapped. Set "datacite" + credentials below to
# register real DOIs; "off" disables identifiers entirely.
# CAUTION: DataCite DOIs are PERMANENT (they can be hidden, never deleted);
# the prefix and repository must stay stable across redeploys. Start with
# the test endpoint (https://api.test.datacite.org) until confident.
QL_DOI_PROVIDER=local
#QL_DATACITE_ENDPOINT=https://api.test.datacite.org
#QL_DATACITE_REPOSITORY_ID=ABCD.EFGH
#QL_DATACITE_PASSWORD=
#QL_DATACITE_PREFIX=10.XXXXX
