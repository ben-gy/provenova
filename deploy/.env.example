# QuantumLedger production environment.
#
#   cp .env.example .env   &&   edit the values below   &&   docker compose up -d --build
#
# Every service reads this file (docker-compose.yml `env_file: [.env]`).
# Keep .env out of version control — it holds real secrets.

# Bare hostname Caddy uses for automatic TLS. Point an A record at the VM's
# public IP first. Caddy provisions a Let's Encrypt cert for this host.
QL_DOMAIN=quantumledger.ben.gy

# Public URL of the deployment (must match QL_DOMAIN, https). Used for
# absolute links, attestation URLs, etc.
QL_BASE_URL=https://quantumledger.ben.gy

# Session cookie signing key. Generate a fresh one:
#   openssl rand -hex 32
QL_SECRET_KEY=

# Ed25519 attestation signing key, base64 of a PKCS8 PEM private key.
# CRITICAL: this must stay STABLE across redeploys — regenerating it
# invalidates every attestation ever issued. Generate once and keep it safe:
#   python scripts/gen_attestation_key.py
# (copy the printed value here). If unset, the server falls back to the file
# at QL_ATTESTATION_KEY_PATH, which is NOT durable on ephemeral filesystems.
QL_ATTESTATION_KEY_B64=

# Postgres password (used by both the postgres container and the DB URL that
# compose builds for the api/worker). Generate:
#   openssl rand -hex 16
POSTGRES_PASSWORD=

# Whether attestation cards are publicly viewable without auth.
QL_PUBLIC_CARDS=true

# DOI minting. "local" (default) mints a stable offline PID — no network,
# works air-gapped. Set "datacite" + credentials to register real DOIs.
# CAUTION: DataCite DOIs are PERMANENT (hidden at best, never deleted); the
# prefix and repository must stay STABLE across redeploys, like the
# attestation key above. Start with https://api.test.datacite.org.
QL_DOI_PROVIDER=local
#QL_DATACITE_ENDPOINT=https://api.test.datacite.org
#QL_DATACITE_REPOSITORY_ID=
#QL_DATACITE_PASSWORD=
#QL_DATACITE_PREFIX=

# Bootstrap admin account email.
QL_ADMIN_EMAIL=admin@quantumledger.local

# QL_DATABASE_URL is assembled automatically by docker-compose.yml from
# POSTGRES_PASSWORD — you do NOT need to set it here. To run against SQLite
# instead of Postgres (tiny single-node deploy), set it explicitly, e.g.:
#   QL_DATABASE_URL=sqlite:////data/quantumledger.db
